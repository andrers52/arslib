{
    "name": "arslib",
    "version": "0.11.0",
    "description": "Andre's TypeScript Utility library",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/andrers52/arslib.git"
    },
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "build": "tsc"
    },
    "author": "Andre Rodrigues da Silva",
    "main": "./dist/index.js",
    "module": "./src/index.ts",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "browser": "./dist/browser/index.js",
            "default": "./src/index.ts"
        },
        "./*": "./src/*.ts"
    },
    "license": "MIT",
    "type": "module",
    "devDependencies": {
        "@types/node": "^25.3.0",
        "@vitest/coverage-v8": "^4.0.18",
        "jsdom": "^28.1.0",
        "ts-morph": "^27.0.2",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}